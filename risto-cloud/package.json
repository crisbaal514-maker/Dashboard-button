{
  "name": "risto-cloud",
  "version": "0.1.0",
  "description": "Risto Cloud — Backend para dispositivos Risto",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/storage/sqlite/migrations dist/storage/sqlite/migrations",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.0.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
