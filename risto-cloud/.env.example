# Risto Cloud Configuration
PORT=3000
HOST=0.0.0.0
DB_PATH=./data/risto-cloud.db
DB_TYPE=sqlite
AUTH_PROVIDER=local
MOCK_ENABLED=true
LOG_LEVEL=info
MIN_PROTOCOL_VERSION=1
MAX_PROTOCOL_VERSION=1
HEARTBEAT_DEFAULT_INTERVAL_MS=30000
HEARTBEAT_STALE_AFTER_MS=90000
TOKEN_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_HOURS=720
